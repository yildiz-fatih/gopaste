{{ define "base" }}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ template "title" . }} - GoPaste</title>
    <link rel="stylesheet" media="(prefers-color-scheme: light)" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/styles/github.css">
    <link rel="stylesheet" media="(prefers-color-scheme: dark)" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/styles/github-dark.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/highlight.min.js"></script>
    <style>
        /* light-dark mode */
        :root { color-scheme: light dark; }
        /* fullscreen layout */
        body, html { margin: 0; padding: 0; height: 100%; overflow: hidden; font-family: monospace; }
        /* main content */
        pre, textarea {
            font-family: inherit;
            font-size: 20px;
            padding: 20px;
            margin: 0;
            width: 100%;
            height: 100%;
            box-sizing: border-box;
            background: transparent;
        }
        textarea { border: none; resize: none; outline: none; }
        pre code { padding: 0 !important; background: transparent !important; }
        pre { overflow: auto; white-space: pre-wrap; word-break: break-word; }
        code { font-family: inherit; }
        /* pin controls to top-right */
        .controls { position: fixed; right: 20px; z-index: 10; }
        /* top controls */
        #top { top: 20px; }
        #top button { background: transparent; border: none; cursor: pointer; padding: 0 8px; }
        #top img { width: 32px; height: 32px; }
        /* invert icons in dark mode */
        @media (prefers-color-scheme: dark) {
            #top img {
                filter: invert(1);
            }
        }
    </style>
</head>
<body>
    {{ template "main" . }}

    <script src="/static/js/main.js"></script>
</body>
</html>
{{ end }}
