{{ define "base" }}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ template "title" }} - GoPaste</title>
    <style>
        /* light-dark mode */
        :root { color-scheme: light dark; }
        /* fullscreen textarea */
        body, html { margin: 0; padding: 0; height: 100%; overflow: hidden; }
        textarea { 
            width: 100%; height: 100%; border: none; padding: 20px; resize: none;
            outline: none; box-sizing: border-box; background: transparent;
        }
        /* pin controls to top-right and bottom-right */
        .controls { position: fixed; right: 20px; z-index: 10; }
        /* top controls */
        #top { top: 20px; }
        #top button { background: transparent; border: none; cursor: pointer; padding: 0 8px; }
        /* bottom controls */
        #bottom { bottom: 20px; }
        #bottom select { background: transparent; color: inherit; }
    </style>
</head>
<body>
    {{ template "main" }}
</body>
</html>
{{ end }}
